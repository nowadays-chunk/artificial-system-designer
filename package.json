{
  "name": "artificial-system-designer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:prepare": "tsc -p tsconfig.tests.json",
    "test:e2e": "node scripts/run-node-test.mjs node_modules/.cache/asd-tests/tests/e2e/modeler-core.spec.js",
    "test:integration": "node scripts/run-node-test.mjs node_modules/.cache/asd-tests/tests/integration/api-contracts.spec.js",
    "test:perf": "node scripts/run-node-test.mjs node_modules/.cache/asd-tests/tests/perf/modeler-bench.spec.js",
    "test": "npm run test:integration && npm run test:e2e",
    "test:ci": "npm run test:prepare && npm run test:integration && npm run test:e2e && npm run test:perf"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
